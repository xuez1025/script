local Tabs = {
    BoatKill = Window:Tab({ Title = "Boat kill", Icon = "ship" }),
    Settings = Window:Tab({ Title = "設定",     Icon = "settings" }),
}

--------------------
-- Boat Kill 分頁 --
--------------------

Tabs.BoatKill:Section({ Title = "Boat Kill" })

Tabs.BoatKill:Button({
    Title = "移除鬼船傷害",
    Desc = "移除鬼船傷害物件",
    Callback = function()
        local count = 0
        for _, v in pairs(game:GetService("Workspace"):GetDescendants()) do
            if v:IsA("TouchTransmitter") then
                local p = v.Parent
                if p and (p.Name:find("Damage") or p.Name:find("Death") or p.Name:find("Kill") or p.Name:find("Lava")) then
                    v:Destroy()
                    count = count + 1
                end
            elseif v.Name == "WaterDamage" or v.Name == "SeaDamage" then
                v:Destroy()
                count = count + 1
            end
        end
        
        WindUI:Notify({ Title = "清理完成", Content = "已移除 " .. count .. " 個危險物件", Duration = 3 })
    end
})

Tabs.BoatKill:Button({
    Title = "傳送到船",
    Desc = "傳送到船隻駕駛座",
    Callback = function()
        local myShip, mySeat = getMyShip()
        local targetSeat = nil
        for _, v in pairs(game.Workspace:GetDescendants()) do
            if v:IsA("VehicleSeat") and v ~= mySeat then
                targetSeat = v
                break 
            end
        end

        if targetSeat then
            teleportToPos(targetSeat.Position)
            WindUI:Notify({ Title = "傳送成功", Content = "已傳送到船長位置", Duration = 2 })
        end
    end
})

local playerDropdown = Tabs.BoatKill:Dropdown({
    Title = "選擇玩家",
    Values = GetPlayerList(),
    Value = nil,
    Callback = function(option)
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr.Name == option then 
                TargetPlayer = plr 
                break 
            end
        end
    end
})

Players.PlayerAdded:Connect(function() playerDropdown:Refresh(GetPlayerList()) end)
Players.PlayerRemoving:Connect(function() playerDropdown:Refresh(GetPlayerList()) end)

Tabs.BoatKill:Toggle({
    Title = "帶船傳送玩家",
    Value = false,
    Callback = function(state)
        shipTpToggle = state
    end
})

Tabs.BoatKill:Section({ Title = "座標傳送 (僅限對應海域)" })

Tabs.BoatKill:Button({ 
    Title = "鬼船 (致命區)", 
    Callback = function() safeTeleport(Vector3.new(941, 252, 32900), "鬼船 (致命區)") end 
})

Tabs.BoatKill:Button({ 
    Title = "豪宅", 
    Callback = function() safeTeleport(Vector3.new(2285, 15, 910), "豪宅") end 
})

Tabs.BoatKill:Button({ 
    Title = "鬼船外", 
    Callback = function() safeTeleport(Vector3.new(922, 125, 32843), "鬼船外") end 
})

--------------------
-- 設定分頁 --
--------------------

Tabs.Settings:Section({ Title = "Boat Kill" })

Tabs.Settings:Keybind({ 
    Title = "快捷鍵", 
    Value = CurrentKey,
    Callback = function(v)
        CurrentKey = v
        if not KeyDisabled then Window:SetToggleKey(Enum.KeyCode[v]) end
    end
})

Tabs.Settings:Toggle({
    Title = "停用快捷鍵",
    Value = false,
    Callback = function(state)
        KeyDisabled = state
        Window:SetToggleKey(state and nil or Enum.KeyCode[CurrentKey])
    end
})

--------------------
-- 背景循環邏輯 --
--------------------

RunService.Heartbeat:Connect(function()
    if not shipTpToggle or not TargetPlayer then return end
    
    local myShip, mySeat = getMyShip()
    if not myShip then return end

    if TargetPlayer.Character then
        local targetHum = TargetPlayer.Character:FindFirstChild("Humanoid")
        local targetHRP = TargetPlayer.Character:FindFirstChild("HumanoidRootPart")

        if targetHum and not targetHum.SeatPart and targetHRP then
            local emptySeat = getTargetSeat(myShip, mySeat)
            if emptySeat then
                local seatOffset = myShip.PrimaryPart.CFrame:Inverse() * emptySeat.CFrame
                myShip:SetPrimaryPartCFrame(targetHRP.CFrame * seatOffset:Inverse())
            else
                myShip:SetPrimaryPartCFrame(targetHRP.CFrame * CFrame.new(0, 5, 0))
            end
        end
    end
end)

Window:SetToggleKey(Enum.KeyCode[CurrentKey])
