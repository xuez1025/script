--- 邏輯實作 ---

local selectedTarget = nil
local shipTpToggle = false

-- 獲取船隻與坐位
local function getMyShip()
    local myChar = LocalPlayer.Character
    if myChar and myChar:FindFirstChild("Humanoid") and myChar.Humanoid.SeatPart then
        local current = myChar.Humanoid.SeatPart
        while current.Parent and not current:IsA("Model") do
            current = current.Parent
        end
        return current, myChar.Humanoid.SeatPart
    end
    return nil, nil
end

-- 執行傳送 (帶船或單人)
local function teleportAction(targetCFrame)
    local myShip, _ = getMyShip()
    local myChar = LocalPlayer.Character
    
    if myShip and myShip.PrimaryPart then
        myShip:SetPrimaryPartCFrame(targetCFrame)
    elseif myChar and myChar:FindFirstChild("HumanoidRootPart") then
        myChar.HumanoidRootPart.CFrame = targetCFrame
    end
end

-- 更新玩家列表
local function updateList()
    for _, child in pairs(PlayerList:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
    for _, p in pairs(Player:GetPlayers()) do
        if p ~= LocalPlayer then
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, 0, 0, 30)
            btn.Text = p.DisplayName
            btn.BackgroundColor3 = (selectedTarget == p) and Color3.fromRGB(100, 100, 180) or Color3.fromRGB(50, 50, 55)
            btn.TextColor3 = Color3.new(1,1,1)
            btn.Parent = PlayerList
            btn.MouseButton1Click:Connect(function() selectedTarget = p; updateList() end)
        end
    end
end

updateList()

