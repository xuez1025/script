    end
})

--------------------
-- 背景循環 (追蹤) --
--------------------

RunService.Heartbeat:Connect(function()
    if shipTpToggle and selectedTargetName then
        local targetPlayer = Player:FindFirstChild(selectedTargetName)
        
        -- 檢查目標玩家是否存在且有角色
        if targetPlayer and targetPlayer.Character then
            local targetHum = targetPlayer.Character:FindFirstChild("Humanoid")
            local targetHRP = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
            local myShip, mySeat = getMyShip()

            -- 如果目標玩家正在坐著，跳過傳送以防邏輯衝突
            if targetHum and targetHum.SeatPart then
                return 
            end
            
            -- 原有的傳送邏輯
            if myShip and targetHRP and mySeat then
                local emptySeat = getTargetSeat(myShip, mySeat)
                if emptySeat then
                    -- 讓船對準空位傳送到玩家位置
                    local relativeOffset = myShip:GetPrimaryPartCFrame():Inverse() * emptySeat.CFrame
                    myShip:SetPrimaryPartCFrame(targetHRP.CFrame * relativeOffset:Inverse())
                else
                    -- 沒空位就直接疊上去
                    myShip:SetPrimaryPartCFrame(targetHRP.CFrame * CFrame.new(0, 5, 0))
                end
            end
        end
    end
end)

-- 初始化選單快捷鍵
Window:SetToggleKey(Enum.KeyCode[CurrentKey])
