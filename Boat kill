-- WindUI 載入
local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

-- 取得服務與玩家
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")

-- 世界檢測變數
local World2 = game.PlaceId == 4442272183 or game.PlaceId == 79091703265657

local CurrentKey = "G"
local KeyDisabled = false

-- 核心變數
local TargetPlayer = nil
local shipTpToggle = false

--------------------
-- 核心邏輯函數 --
--------------------

local function getMyShip()
    local myChar = LocalPlayer.Character
    if myChar and myChar:FindFirstChild("Humanoid") and myChar.Humanoid.SeatPart then
        local current = myChar.Humanoid.SeatPart
        local seat = myChar.Humanoid.SeatPart
        while current.Parent and not current:IsA("Model") do
            current = current.Parent
        end
        return current, seat
    end
    return nil, nil
end

local function getTargetSeat(ship, mySeat)
    for _, part in pairs(ship:GetDescendants()) do
        if (part:IsA("Seat") or part:IsA("VehicleSeat")) and part ~= mySeat and not part.Occupant then
            return part
        end
    end
    return nil
end

local function teleportToPos(pos)
    local myShip, _ = getMyShip()
    local myChar = LocalPlayer.Character
    if myShip then
        myShip:SetPrimaryPartCFrame(CFrame.new(pos + Vector3.new(0, 10, 0)))
    elseif myChar and myChar:FindFirstChild("HumanoidRootPart") then
        myChar.HumanoidRootPart.CFrame = CFrame.new(pos + Vector3.new(0, 5, 0))
    end
end

-- 玩家列表獲取
local function GetPlayerList()
    local list = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then 
            table.insert(list, plr.Name) 
        end
    end
    return list
end

-- 檢測並傳送的封裝函數
local function safeTeleport(pos, name)
    if World2 then
        teleportToPos(pos)
        WindUI:Notify({ Title = "傳送中", Content = "正在前往: " .. name, Duration = 2 })
    else
        WindUI:Notify({ Title = "傳送失敗", Content = "此座標僅限特定海域使用", Duration = 3 })
    end
end

-- GUI 視窗建立 --

local Window = WindUI:CreateWindow({
        Title       = "Xu-hub",
