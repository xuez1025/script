--- 邏輯控制變數 ---
local moveSpeed = 500
local isMoving = false
local moveConn = nil -- 儲存 Heartbeat 連線
local inputConn = nil -- 儲存 快捷鍵 連線

local function updateSpeedDisplay()
    speed.Text = tostring(moveSpeed)
end

-- ===== 核心控制：CFrame 位移模式 =====
local function toggleMoveMode()
    isMoving = not isMoving
    onof.Text = isMoving and "位移:開" or "位移:關"
    onof.BackgroundColor3 = isMoving and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(80, 80, 80)

    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")

    if isMoving and root then
        root.Anchored = true
        if moveConn then moveConn:Disconnect() end -- 防止重複連接
        moveConn = RunService.Heartbeat:Connect(function(dt)
            if not isMoving or not root.Parent then return end
            
            local cam = workspace.CurrentCamera
            local moveVec = Vector3.new(0, 0, 0)
            
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveVec = moveVec + cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveVec = moveVec - cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveVec = moveVec - cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveVec = moveVec + cam.CFrame.RightVector end

            if moveVec.Magnitude > 0 then
                root.CFrame = root.CFrame + (moveVec.Unit * moveSpeed * dt)
            end
        end)
    else
        if root then root.Anchored = false end
        if moveConn then moveConn:Disconnect(); moveConn = nil end
    end
end

-- 將快捷鍵監聽賦值給變數，以便後續關閉
inputConn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == Enum.KeyCode.G then
        toggleMoveMode()
    end
end)

onof.MouseButton1Click:Connect(toggleMoveMode)

-- ===== 速度調整 =====
plus.MouseButton1Click:Connect(function()
    moveSpeed = math.min(1000, moveSpeed + 100)
    updateSpeedDisplay()
end)

mine.MouseButton1Click:Connect(function()
    moveSpeed = math.max(100, moveSpeed - 100)
    updateSpeedDisplay()
end)

-- ===== UI 收納與關閉 =====
closebutton.MouseButton1Click:Connect(function()
    isMoving = false
    -- 1. 斷開位移連線
    if moveConn then moveConn:Disconnect() end
    -- 2. 斷開快捷鍵連線 (解決你的需求)
    if inputConn then inputConn:Disconnect() end
    
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if root then root.Anchored = false end
    
    main:Destroy()
end)

mini.MouseButton1Click:Connect(function()
