-- 關閉與縮小按鈕
local function createTopBtn(text, pos, color)
    local btn = Instance.new("TextButton")
    btn.Parent = TitleBar
    btn.Text = text
    btn.Size = UDim2.new(0, 30, 0, 30)
    btn.Position = pos
    btn.BackgroundColor3 = color
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.BorderSizePixel = 0
    btn.Font = Enum.Font.GothamBold
    return btn
end

local CloseBtn = createTopBtn("×", UDim2.new(1, -30, 0, 0), Color3.fromRGB(180, 50, 50))
local MinimizeBtn = createTopBtn("-", UDim2.new(1, -60, 0, 0), Color3.fromRGB(60, 60, 70))

-- 內容
ContentFrame.Name = "ContentFrame"
ContentFrame.Parent = MainFrame
ContentFrame.BackgroundTransparency = 1
ContentFrame.Position = UDim2.new(0, 0, 0, 30)
ContentFrame.Size = UDim2.new(1, 0, 1, -30)

StatusLabel.Parent = ContentFrame
StatusLabel.Text = "狀態:可順移"
StatusLabel.Size = UDim2.new(1, 0, 0.6, 0)
StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 150)
StatusLabel.Font = Enum.Font.Gotham
StatusLabel.TextSize = 14

InstructionLabel.Parent = ContentFrame
InstructionLabel.Text = "快捷鍵(G)"
InstructionLabel.Size = UDim2.new(1, 0, 0.4, 0)
InstructionLabel.Position = UDim2.new(0, 0, 0.5, 0)
InstructionLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
InstructionLabel.Font = Enum.Font.Gotham
InstructionLabel.TextSize = 11

-- --- 核心邏輯：瞬間傳送與面向調整 --- --

local function performDash()
    if not guiActive or not canDash then return end
    
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    
    if rootPart then
        canDash = false
        StatusLabel.Text = "狀態:冷卻"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
        
        -- 獲取相機視角的方向
        local lookDir = Camera.CFrame.LookVector
        
        -- 計算新的位置與旋轉
        -- CFrame.new(當前位置 + 位移, 當前位置 + 位移 + 視角方向) 
        -- 這會讓 rootPart 瞬間移動並「看向」那個方向
        local targetPos = rootPart.Position + (lookDir * dashDistance)
        rootPart.CFrame = CFrame.new(targetPos, targetPos + lookDir)
        
        task.wait(dashCooldown)
        canDash = true
        StatusLabel.Text = "狀態:可順移"
        StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 150)
    end
end

-- 迴圈監控 G 鍵
task.spawn(function()
    while true do
        if isHoldingG and guiActive then
            performDash()
        end
        task.wait(0.05)
        if not ScreenGui.Parent then break end
    end
end)

-- --- 交互功能 --- --

-- 鍵盤事件
UserInputService.InputBegan:Connect(function(input, processed)
    if processed or not guiActive then return end
    if input.KeyCode == Enum.KeyCode.G then isHoldingG = true end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.G then isHoldingG = false end
end)

-- GUI 拖動
local dragging, dragInput, dragStart, startPos
TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

TitleBar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)

-- 縮小邏輯
local minimized = false
MinimizeBtn.MouseButton1Click:Connect(function()
    minimized = not minimized
    if minimized then
        MainFrame:TweenSize(UDim2.new(0, 180, 0, 30), "Out", "Quad", 0.2, true)
        ContentFrame.Visible = false
        MinimizeBtn.Text = "+"
    else
        MainFrame:TweenSize(UDim2.new(0, 180, 0, 120), "Out", "Quad", 0.2, true)
        ContentFrame.Visible = true
        MinimizeBtn.Text = "-"
    end
end)

-- 關閉邏輯 (徹底停止)
CloseBtn.MouseButton1Click:Connect(function()
    guiActive = false
    isHoldingG = false
    ScreenGui:Destroy()
end)

print("腳本已整合：人偶面向現在與視角衝刺方向一致。")
