-- 效能監測變數
local frameCount = 0
local lastUpdate = tick()
local currentFps = 0

-- FPS 計數器
RunService.RenderStepped:Connect(function()
    frameCount += 1
end)

-- 主更新迴圈
task.spawn(function()
    while true do
        local now = tick()
        local deltaTime = now - lastUpdate
        
        -- 每 0.5 秒更新一次 UI，避免過度消耗效能
        task.wait(0.5)
        
        -- 1. 更新 FPS (計算過去一段時間內的平均幀率)
        if deltaTime >= 1 then
            currentFps = frameCount / deltaTime
            frameCount = 0
            lastUpdate = now
        end
        if FPSSection then FPSSection:SetTitle(string.format("FPS: %.0f/s", currentFps)) end

        -- 2. 更新人數
        if PlayerSection then 
            PlayerSection:SetTitle(string.format("Players: %d/%d", #Players:GetPlayers(), Players.MaxPlayers or 20)) 
        end

        -- 3. 更新本地時間
        local t = os.date("*t")
        if TimeSection then 
            TimeSection:SetTitle(string.format("Local Time: %04d-%02d-%02d %02d:%02d:%02d",
                t.year, t.month, t.day, t.hour, t.min, t.sec))
        end

        -- 4. 更新 Ping (修正倍率為 1000)
        if PingSection then 
            local ping = LocalPlayer:GetNetworkPing() * 1000
            PingSection:SetTitle(string.format("Ping: %.0f ms", ping))
        end

        -- 5. 更新遊戲運行時間
        local gt = math.floor(Workspace.DistributedGameTime + 0.5)
        if GameTimeSection then 
            GameTimeSection:SetTitle(string.format("Game Time: %02d:%02d:%02d",
                math.floor(gt / 3600), math.floor(gt / 60) % 60, gt % 60))
        end
    end
end)

