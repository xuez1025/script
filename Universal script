-- 2. 功能核心 (智能判斷型 ServerCore)
local ServerCore = {}

function ServerCore:TeleportToServer(jobId)
    if not jobId or jobId == "" then return end
    
    task.spawn(function()
        -- 優先嘗試 Blox Fruits 內建方式
        if ServerBrowserRemote then
            local success = pcall(function()
                ServerBrowserRemote:InvokeServer("teleport", jobId)
            end)
            if success then return end -- 如果成功執行則結束
        end

        -- 如果沒有內建方式或內建方式失敗，使用系統強制跳轉 (通用)
        pcall(function()
            TeleportService:TeleportToPlaceInstance(PlaceId, jobId, LocalPlayer)
        end)
    end)
end

function ServerCore:FindAndHop(mode)
    task.spawn(function()
        -- 獲取伺服器列表
        local url = "https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
        local success, response = pcall(function()
            return HttpService:JSONDecode(game:HttpGet(url))
        end)

        if not (success and response and response.data) then 
            WindUI:Notify({ Title = "錯誤", Content = "無法獲取伺服器列表", Duration = 3 })
            return 
        end

        local validServers = {}
        for _, server in ipairs(response.data) do
            -- 排除當前伺服器且確保有空位
            if server.id ~= JobId and server.playing < server.maxPlayers then
                table.insert(validServers, {id = server.id, count = server.playing})
            end
        end

        if #validServers == 0 then 
            WindUI:Notify({ Title = "提示", Content = "目前沒有合適的伺服器", Duration = 3 })
            return 
        end

        local targetJobId
        if mode == "small" then
            -- 排序獲取人數最少的
            table.sort(validServers, function(a, b) return a.count < b.count end)
            targetJobId = validServers[1].id
        else
            -- 隨機跳服
            targetJobId = validServers[math.random(1, #validServers)].id
        end

        self:TeleportToServer(targetJobId)
    end)
end

