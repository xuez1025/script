local function ToggleGameUI(state)
    local PlayerGui = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
    
    if state then
        -- 隱藏邏輯
        for _, gui in pairs(PlayerGui:GetChildren()) do
            -- 排除自己的腳本 UI (假設你的 UI 名字叫 "MyCustomGui")
            -- 同時只處理原本是開啟狀態的 UI
            if gui:IsA("ScreenGui") and gui.Enabled and gui.Name ~= "MyCustomGui" then
                table.insert(HiddenUIs, gui)
                gui.Enabled = false
            end
        end
    else
        -- 恢復邏輯
        for _, gui in pairs(HiddenUIs) do
            if gui and gui.Parent then
                gui.Enabled = true
            end
        end
        -- 清空清單，避免重複疊加
        table.clear(HiddenUIs)
    end
end

