local function onPlayerAdded(p)
    p.CharacterAdded:Connect(function()
        if ESP_SETTINGS.Master then
            task.wait(0.5)
            createESP(p)
        end
    end)
end

Players.PlayerAdded:Connect(onPlayerAdded)
for _, p in ipairs(Players:GetPlayers()) do onPlayerAdded(p) end

RunService.RenderStepped:Connect(function()
    if not ESP_SETTINGS.Master then return end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            local head = p.Character:FindFirstChild("Head")

            if hum and hrp and head then
                local bill = head:FindFirstChild("ESP_Billboard")
                if bill then
                    local info = bill:FindFirstChild("Info")
                    local barBG = bill:FindFirstChild("HP_Background")
                    local myHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

                    local display = ""
                    if ESP_SETTINGS.ShowName then display = p.Name .. "\n" end
                    if ESP_SETTINGS.ShowHealth then display = display .. "HP: " .. math.floor(hum.Health) .. " " end
                    if ESP_SETTINGS.ShowDistance and myHRP then
                        local dist = math.floor((myHRP.Position - hrp.Position).Magnitude)
                        display = display .. " " .. dist .. "m"
                    end
                    
                    if info then info.Text = display end
                    if barBG then 
                        barBG.Visible = ESP_SETTINGS.ShowHealth 
                        local fill = barBG:FindFirstChild("HP_Fill")
                        if fill then
                            local ratio = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                            fill.Size = UDim2.new(ratio, 0, 1, 0)
                            fill.BackgroundColor3 = ratio > 0.6 and Color3.fromRGB(0, 255, 0) or ratio > 0.3 and Color3.fromRGB(255, 255, 0) or Color3.fromRGB(255, 0, 0)
                        end
                    end
                else
                    createESP(p)
                end
                updateTracer(p, hrp)
            end
        end
    end
end)

local Hitbox = { Enabled = false, Size = 1, Transparency = 0.5, Connections = {} }

-- Hitbox
local function getRoot(char) return char:FindFirstChild("HumanoidRootPart") end

function Hitbox:ApplyToPlayer(plr)
    if plr == LocalPlayer or not plr.Character then return end
    local r = getRoot(plr.Character)
    if r and r:IsA("BasePart") then
        r.CanCollide  = false
        r.Size        = Vector3.new(self.Size, self.Size, self.Size)
        r.Transparency= self.Transparency
    end
end

function Hitbox:ApplyAll()
    for _, plr in pairs(Players:GetPlayers()) do self:ApplyToPlayer(plr) end
end

function Hitbox:Start()
    if self.Enabled then return end
    self.Enabled = true
    self:ApplyAll()
    self.Connections.PlayerAdded = Players.PlayerAdded:Connect(function(plr)
        plr.CharacterAdded:Connect(function()
            task.wait(1)
            if self.Enabled then self:ApplyToPlayer(plr) end
        end)
    end)
end

function Hitbox:Stop() self.Enabled = false end

local MIN_LIMIT = 100   -- 滑桿最小值
local MAX_LIMIT = 5000  -- 滑桿最大值
local STEP = 10         -- 每次跳動的間隔 (5000 範圍較大，建議設 10 以上較好拉)

local function UpdateZoomLimit(value)
    local targetValue = tonumber(value)
    if not targetValue then return end

    -- 確保數值在 100 ~ 5000 之間
    targetValue = math.clamp(targetValue, MIN_LIMIT, MAX_LIMIT)

    -- 關鍵：只設定最大距離，最小距離保持在極小值（例如 0.5）
    -- 這樣你才能在 0.5 到你設定的值之間自由捲動滾輪
    LocalPlayer.CameraMaxZoomDistance = targetValue
    LocalPlayer.CameraMinZoomDistance = 0.5
end

