local isMinimized = false

local function toggleMinimize()
    isMinimized = not isMinimized
    if isMinimized then
        Frame.Size = UDim2.new(0, 340, 0, 40)
        ContentFrame.Visible = false
        MinimizeButton.Text = "+"
        MinimizeButton.BackgroundColor3 = Color3.fromRGB(80, 200, 80)
    else
        Frame.Size = UDim2.new(0, 340, 0, 300)
        ContentFrame.Visible = true
        MinimizeButton.Text = "-"
        MinimizeButton.BackgroundColor3 = Color3.fromRGB(50, 150, 220)
    end
end

MinimizeButton.MouseButton1Click:Connect(toggleMinimize)

-- 核心變數
local SilentAimEnabled = false
local UseClosestMode = true
local SelectedTargetPlayer = nil
local PredictionEnabled = true
local PredictionAmount = 0.135
local maxRange = math.huge

local renderConnection
local PlayersPosition = nil
local selectedButton = nil

local function getHRP(model)
    return model and model:FindFirstChild("HumanoidRootPart")
end

local function getPredictedPos(hrp)
    if not hrp then return nil end
    if not PredictionEnabled then return hrp.Position end
    local vel = hrp.Velocity
    return hrp.Position + (vel * PredictionAmount)
end

local function getClosestEnemy()
    local lpHRP = getHRP(player.Character)
    if not lpHRP then return nil end
    
    local closest, minDist = nil, math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local hrp = getHRP(plr.Character)
            local hum = plr.Character:FindFirstChildOfClass("Humanoid")
            if hrp and hum and hum.Health > 0 then
                local dist = (hrp.Position - lpHRP.Position).Magnitude
                if dist < minDist then
                    minDist = dist
                    closest = plr
                end
            end
        end
    end
    return closest
end

local function updatePlayerList()
    for _, child in ipairs(PlayerListFrame:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    selectedButton = nil
    
    local count = 0
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local hrp = getHRP(plr.Character)
            local hum = plr.Character:FindFirstChildOfClass("Humanoid")
            if hrp and hum and hum.Health > 0 then
                local btn = Instance.new("TextButton")
                btn.Size = UDim2.new(1, -12, 0, 32)
                btn.BackgroundColor3 = Color3.fromRGB(65, 65, 65)
                btn.Text = plr.Name .. (plr.Team and " ["..plr.Team.Name.."]" or "")
                btn.TextColor3 = Color3.fromRGB(255, 255, 255)
                btn.Font = Enum.Font.Gotham
                btn.TextSize = 14
                btn.TextXAlignment = Enum.TextXAlignment.Left
                btn.Parent = PlayerListFrame
                
                if SelectedTargetPlayer == plr then
                    btn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
                    selectedButton = btn
                end
                
                btn.MouseButton1Click:Connect(function()
                    if selectedButton then
                        selectedButton.BackgroundColor3 = Color3.fromRGB(65, 65, 65)
                    end
                    SelectedTargetPlayer = plr
                    selectedButton = btn
                    btn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
                    
                    StatusLabel.Text = "已選擇： " .. plr.Name .. " (指定模式)"
                    if UseClosestMode then
                        StatusLabel.Text = "已選擇： " .. plr.Name .. " (但目前為最近模式)"
                    end
                end)
                
                count = count + 1
            end
        end
    end
    
    PlayerListFrame.CanvasSize = UDim2.new(0, 0, 0, count * 38)
end

spawn(function()
    while task.wait(4) do
        if ScreenGui.Parent then
            updatePlayerList()
        else
            break
        end
    end
end)

updatePlayerList()

local function startAimbot()
    if renderConnection then return end
    renderConnection = RunService.RenderStepped:Connect(function()
        if not SilentAimEnabled then return end
        
        local target = UseClosestMode and getClosestEnemy() or SelectedTargetPlayer
        
        if not target or not target.Character then
            PlayersPosition = nil
            return
        end
        
        local hrp = getHRP(target.Character)
        if not hrp then return end
        
        PlayersPosition = getPredictedPos(hrp)
    end)
end

local function stopAimbot()
    if renderConnection then
        renderConnection:Disconnect()
        renderConnection = nil
    end
    PlayersPosition = nil
end

-- 尋找 Mouse 模組
local MouseModule = game:GetService("ReplicatedStorage"):FindFirstChild("Mouse", true)
local Mouse = nil
if MouseModule then
    local success, mod = pcall(require, MouseModule)
    if success and type(mod) == "table" then
        Mouse = mod
    end
end

-- Silent Aim 核心 - Heartbeat 更新 Mouse.Hit
RunService.Heartbeat:Connect(function()
    if SilentAimEnabled and PlayersPosition and Mouse then
        pcall(function()
            Mouse.Hit = CFrame.new(PlayersPosition)
            Mouse.Target = nil
        end)
    end
end)

-- 開關按鈕
ToggleButton.MouseButton1Click:Connect(function()
    SilentAimEnabled = not SilentAimEnabled
    if SilentAimEnabled then
        ToggleButton.Text = "Aimbot: ON"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
        local mode = UseClosestMode and "最近敵人" or (SelectedTargetPlayer and SelectedTargetPlayer.Name or "無指定")
        StatusLabel.Text = "已開啟 - 目標：" .. mode
        startAimbot()
    else
        ToggleButton.Text = "Aimbot: OFF"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        StatusLabel.Text = "已關閉 (快捷鍵 G)"
        stopAimbot()
    end
end)

