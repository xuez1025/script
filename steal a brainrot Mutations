end)

-- 快捷鍵監聽 (增加判斷 ScreenGui 是否還存在)
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe or not ScreenGui.Parent then return end -- 如果 GUI 被毀掉，快捷鍵不再觸發
    if input.KeyCode == Enum.KeyCode.Q then UpdateAnti()
    elseif input.KeyCode == Enum.KeyCode.R then UpdateAuto() end
end)

