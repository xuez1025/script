-- 拖動功能
local dragging, dragStart, startPos
MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true; dragStart = input.Position; startPos = MainFrame.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

-- 按鈕工廠
local function CreateButton(name, pos, toggleKey)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9, 0, 0, 40)
    btn.Position = pos
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    btn.Text = name .. ": OFF [" .. toggleKey .. "]"
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 12
    btn.Parent = ContentFrame
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    return btn
end

local AntiBtn = CreateButton("Anti-Attack", UDim2.new(0.05, 0, 0.1, 0), "Q")
local AutoBtn = CreateButton("Auto-Buy", UDim2.new(0.05, 0, 0.5, 0), "R")

-- 更新函數
local function UpdateAnti()
    State.AntiAttack = not State.AntiAttack
    AntiBtn.BackgroundColor3 = State.AntiAttack and Color3.fromRGB(80, 180, 100) or Color3.fromRGB(40, 40, 50)
    AntiBtn.Text = "Anti-Attack: " .. (State.AntiAttack and "ON" or "OFF") .. " [Q]"
    ShowNotice("Anti-Attack: " .. (State.AntiAttack and "開啟" or "關閉"))
end

local function UpdateAuto()
    State.AutoBuy = not State.AutoBuy
    AutoBtn.BackgroundColor3 = State.AutoBuy and Color3.fromRGB(60, 150, 255) or Color3.fromRGB(40, 40, 50)
    AutoBtn.Text = "Auto-Buy: " .. (State.AutoBuy and "ON" or "OFF") .. " [R]"
    ShowNotice("Auto-Buy: " .. (State.AutoBuy and "開啟" or "關閉"))
end

AntiBtn.MouseButton1Click:Connect(UpdateAnti)
AutoBtn.MouseButton1Click:Connect(UpdateAuto)

-- 縮小功能
MinBtn.MouseButton1Click:Connect(function()
    State.IsMinimized = not State.IsMinimized
