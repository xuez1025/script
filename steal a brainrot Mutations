-- 開關組件工廠（不動核心邏輯）
local function CreateToggle(name, id, key)
    local TFrame = Instance.new("Frame", Content)
    TFrame.Size = UDim2.new(1, 0, 0, 40)
    TFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
    Instance.new("UICorner", TFrame).CornerRadius = UDim.new(0, 8)
    
    local TLbl = Instance.new("TextLabel", TFrame)
    TLbl.Size = UDim2.new(0.6, 0, 1, 0)
    TLbl.Position = UDim2.new(0, 12, 0, 0)
    TLbl.BackgroundTransparency = 1
    TLbl.Text = name .. (key and " ["..key.Name.."]" or "")
    TLbl.TextColor3 = Color3.new(0.9, 0.9, 0.9)
    TLbl.TextSize = 12
    TLbl.Font = Enum.Font.GothamMedium
    TLbl.TextXAlignment = Enum.TextXAlignment.Left
    
    local SBG = Instance.new("Frame", TFrame)
    SBG.Size = UDim2.new(0, 34, 0, 16)
    SBG.Position = UDim2.new(1, -44, 0.5, -8)
    SBG.BackgroundColor3 = Color3.fromRGB(60, 60, 65)
    Instance.new("UICorner", SBG).CornerRadius = UDim.new(1, 0)
    
    local SDot = Instance.new("Frame", SBG)
    SDot.Size = UDim2.new(0, 12, 0, 12)
    SDot.Position = UDim2.new(0, 2, 0.5, -6)
    SDot.BackgroundColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", SDot).CornerRadius = UDim.new(1, 0)
    
    local function UpdateUI()
        local enabled = LogicState[id]
        TweenService:Create(SBG, TweenInfo.new(0.2), {BackgroundColor3 = enabled and Color3.fromRGB(0, 210, 120) or Color3.fromRGB(60, 60, 65)}):Play()
        TweenService:Create(SDot, TweenInfo.new(0.2), {Position = enabled and UDim2.new(1, -14, 0.5, -6) or UDim2.new(0, 2, 0.5, -6)}):Play()
    end
    
    local function Exec()
        if not GuiEnabled then return end
        LogicState[id] = not LogicState[id]
        UpdateUI()
        ShowNotice(name .. (LogicState[id] and " 已啟動" or " 已關閉"))
    end
    
    TFrame.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then 
            Exec() 
        end
    end)
    
    return Exec
end

