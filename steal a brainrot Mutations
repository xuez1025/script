-- ================== 系統監聽與循環 ==================
-- 拖動功能
local dragging, dragStart, startPos
Frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then 
        dragging = true
        dragStart = input.Position
        startPos = Frame.Position 
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        Frame.Position = UDim2.new(
            startPos.X.Scale, 
            startPos.X.Offset + delta.X, 
            startPos.Y.Scale, 
            startPos.Y.Offset + delta.Y
        )
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then 
        dragging = false 
    end
end)

-- 按鍵監聽（增加 GuiEnabled 判斷）
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe or not GuiEnabled then return end
    
    lastInputTime = os.time()
    
    if input.KeyCode == Settings.Keybinds.AntiAttack then
        toggleAntiAttack()
    elseif input.KeyCode == Settings.Keybinds.AutoBuy then
        toggleAutoBuy()
    end
end)

-- 主循環
RunService.Heartbeat:Connect(function()
    if LogicState.AntiAttack then
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if root then
            root.AssemblyLinearVelocity = Vector3.new(0, root.AssemblyLinearVelocity.Y, 0)
        end
    end
    
    AfkDisplay.Text = "IDLE TIME: " .. formatTime(os.time() - lastInputTime)
end)

