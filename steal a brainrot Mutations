local function ShowNotice(msg)
    local note = Instance.new("TextLabel")
    note.Size = UDim2.new(1, 0, 0, 35)
    note.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
    note.TextColor3 = Color3.new(1, 1, 1)
    note.Text = "  " .. msg
    note.Font = Enum.Font.GothamSemibold
    note.TextSize = 11
    note.TextXAlignment = Enum.TextXAlignment.Left
    note.Parent = notifContainer
    Instance.new("UICorner", note).CornerRadius = UDim.new(0, 6)
    local st = Instance.new("UIStroke", note)
    st.Color = Color3.fromRGB(90, 130, 255)
    
    note.Position = UDim2.new(1.5, 0, 0, 0)
    TweenService:Create(note, TweenInfo.new(0.4, Enum.EasingStyle.Back), {Position = UDim2.new(0, 0, 0, 0)}):Play()
    
    task.delay(3, function()
        local t = TweenService:Create(note, TweenInfo.new(0.5), {TextTransparency = 1, BackgroundTransparency = 1})
        t:Play()
        t.Completed:Connect(function() note:Destroy() end)
    end)
end

-- ================== 核心邏輯：Anti-Attack ==================
RunService.Heartbeat:Connect(function()
    if State.AntiAttack then
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            char.HumanoidRootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        end
    end
end)

-- ================== 核心邏輯：Auto Buy ==================
local function IsWhitelisted(prompt)
    if #Config.Whitelist == 0 then return true end
    local text = (prompt.ObjectText .. prompt.ActionText):lower()
    for _, word in pairs(Config.Whitelist) do
        if text:find(word:lower()) then return true end
    end
    return false
end

local function TriggerPromptDirectly(prompt)
    if not prompt or not prompt.Enabled then return end
    task.spawn(function()
        prompt:InputHoldBegin()
        if prompt.HoldDuration > 0 then
            task.wait(prompt.HoldDuration + 0.05)
        end
        prompt:InputHoldEnd()
    end)
end

ProximityPromptService.PromptShown:Connect(function(prompt)
    if IsWhitelisted(prompt) then currentPrompt = prompt end
end)

ProximityPromptService.PromptHidden:Connect(function(prompt)
    if currentPrompt == prompt then currentPrompt = nil end
end)

task.spawn(function()
    while true do
        if State.AutoBuy and currentPrompt then
            if currentPrompt.Parent and currentPrompt.Enabled then
                TriggerPromptDirectly(currentPrompt)
                task.wait(math.random(Config.MinWait * 100, Config.MaxWait * 100) / 100)
            else
                currentPrompt = nil
                task.wait(0.1)
            end
        else
            task.wait(0.2)
        end
    end
end)

