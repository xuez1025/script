-- ================== 核心 Loop ==================
RunService.Heartbeat:Connect(function()
    if antiKnockbackEnabled then
        local char = player.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            char.HumanoidRootPart.AssemblyLinearVelocity = Vector3.zero
        end
    end

    local currentTime = os.time()
    afkTimeValue = currentTime - lastInputTime
    afkLabel.Text = "Idle: " .. formatTime(afkTimeValue)
    afkLabel.BackgroundTransparency = (afkTimeValue > 0) and 0 or 0.5
    
    if buttons["AutoBuy"] then
        buttons["AutoBuy"].update()
    end
end)

-- ================== 快捷鍵監聽 ==================
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.R then
        if buttons["AutoBuy"] then buttons["AutoBuy"].toggle() end
    elseif input.KeyCode == Enum.KeyCode.Q then
        if buttons["AntiAttack"] then buttons["AntiAttack"].toggle() end
    end
end)

