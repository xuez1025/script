local function ShowNotice(msg)
    local note = Instance.new("TextLabel")
    note.Size = UDim2.new(1, 0, 0, 40)
    note.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    note.BackgroundTransparency = 0.2
    note.TextColor3 = Color3.new(1, 1, 1)
    note.Text = "  " .. msg
    note.Font = Enum.Font.GothamSemibold
    note.TextSize = 13
    note.TextXAlignment = Enum.TextXAlignment.Left
    note.Parent = notifContainer
    Instance.new("UICorner", note).CornerRadius = UDim.new(0, 6)
    
    note.Position = UDim2.new(1.5, 0, 0, 0)
    TweenService:Create(note, TweenInfo.new(0.4, Enum.EasingStyle.Back), {Position = UDim2.new(0, 0, 0, 0)}):Play()
    
    task.delay(5, function()
        local t = TweenService:Create(note, TweenInfo.new(0.5), {TextTransparency = 1, BackgroundTransparency = 1})
        t:Play()
        t.Completed:Connect(function() note:Destroy() end)
    end)
end

