-- ================== 按鈕與邏輯整合系統 ==================
local buttons = {}

local function AddToggle(name, id, callback)
    local state = false
    local btn = Instance.new("TextButton")
    btn.Text = name
    btn.BackgroundColor3 = COLOR_OFF
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 14
    btn.Parent = container
    Instance.new("UICorner", btn)

    local function updateVisuals()
        local targetColor = state and COLOR_ON or COLOR_OFF
        if id == "AutoBuy" and state and not canBuy then
            targetColor = COLOR_WAIT
        end
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = targetColor}):Play()
    end

    local function toggle()
        state = not state
        callback(state)
        updateVisuals()
        ShowNotice(name .. (state and " 已啟動" or " 已停用"))
    end

    btn.MouseButton1Click:Connect(toggle)
    
    buttons[id] = {
        btn = btn, 
        update = updateVisuals, 
        toggle = toggle
    }
end

AddToggle("Anti Attack (Q)", "AntiAttack", function(state) antiKnockbackEnabled = state end)
