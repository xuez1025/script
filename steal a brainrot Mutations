-- ================== 開關組件工廠 ==================
local function CreateToggle(name, id, keybindText)
    local ToggleFrame = Instance.new("Frame")
    ToggleFrame.Size = UDim2.new(1, 0, 0, 42)
    ToggleFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
    ToggleFrame.Parent = Content
    Instance.new("UICorner", ToggleFrame).CornerRadius = UDim.new(0, 8)

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(0.6, 0, 1, 0)
    Label.Position = UDim2.new(0, 12, 0, 0)
    Label.BackgroundTransparency = 1
    Label.Text = name .. (keybindText and (" ["..keybindText.."]") or "")
    Label.TextColor3 = Color3.new(1,1,1)
    Label.TextSize = 13
    Label.Font = Enum.Font.GothamSemibold
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = ToggleFrame

    local SwitchBG = Instance.new("Frame")
    SwitchBG.Size = UDim2.new(0, 36, 0, 18)
    SwitchBG.Position = UDim2.new(1, -48, 0.5, -9)
    SwitchBG.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
    SwitchBG.Parent = ToggleFrame
    Instance.new("UICorner", SwitchBG).CornerRadius = UDim.new(1, 0)

    local SwitchDot = Instance.new("Frame")
    SwitchDot.Size = UDim2.new(0, 14, 0, 14)
    SwitchDot.Position = UDim2.new(0, 2, 0.5, -7)
    SwitchDot.BackgroundColor3 = Color3.new(1,1,1)
    SwitchDot.Parent = SwitchBG
    Instance.new("UICorner", SwitchDot).CornerRadius = UDim.new(1, 0)

    local function UpdateUI(state)
        local tweenInfo = TweenInfo.new(0.2)
        if state then
            TweenService:Create(SwitchBG, tweenInfo, {BackgroundColor3 = Color3.fromRGB(80, 180, 100)}):Play()
            TweenService:Create(SwitchDot, tweenInfo, {Position = UDim2.new(1, -16, 0.5, -7)}):Play()
        else
            TweenService:Create(SwitchBG, tweenInfo, {BackgroundColor3 = Color3.fromRGB(60, 60, 70)}):Play()
            TweenService:Create(SwitchDot, tweenInfo, {Position = UDim2.new(0, 2, 0.5, -7)}):Play()
        end
    end

    local function Toggle()
        LogicState[id] = not LogicState[id]
        
        -- 特殊邏輯：自動購買狀態改變時，更新當前的 Prompt 狀態
        if id == "AutoBuy" and currentPrompt then
            if LogicState.AutoBuy then
                currentPrompt.HoldDuration = 0
            else
                currentPrompt.HoldDuration = originalDurations[currentPrompt] or 0.5
            end
        end

        UpdateUI(LogicState[id])
        ShowNotice(name .. (LogicState[id] and " ON" or " OFF"))
    end

    ToggleFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then Toggle() end
    end)

    return Toggle
end

