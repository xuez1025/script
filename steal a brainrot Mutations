-- ================== 通知系統 ==================
local function CreateNotifySystem()
    local sg = Instance.new("ScreenGui", LocalPlayer:WaitForChild("PlayerGui"))
    sg.Name = "ModernNotif_Core"
    
    local container = Instance.new("Frame", sg)
    container.Size = UDim2.new(0, 200, 0, 400)
    container.Position = UDim2.new(1, -210, 1, -420)
    container.BackgroundTransparency = 1
    
    local layout = Instance.new("UIListLayout", container)
    layout.VerticalAlignment = Enum.VerticalAlignment.Bottom
    layout.Padding = UDim.new(0, 8)
    
    return function(msg)
        local note = Instance.new("TextLabel", container)
        note.Size = UDim2.new(1, 0, 0, 35)
        note.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
        note.TextColor3 = Color3.new(1, 1, 1)
        note.Text = "  " .. msg
        note.Font = Enum.Font.GothamSemibold
        note.TextSize = 11
        note.TextXAlignment = Enum.TextXAlignment.Left
        Instance.new("UICorner", note).CornerRadius = UDim.new(0, 6)
        local stroke = Instance.new("UIStroke", note)
        stroke.Color = Color3.fromRGB(90, 130, 255)
        
        note.Position = UDim2.new(1.5, 0, 0, 0)
        TweenService:Create(note, TweenInfo.new(0.4, Enum.EasingStyle.Back), {Position = UDim2.new(0, 0, 0, 0)}):Play()
        
        task.delay(2.5, function()
            local t = TweenService:Create(note, TweenInfo.new(0.5), {TextTransparency = 1, BackgroundTransparency = 1})
            t:Play()
            t.Completed:Connect(function() note:Destroy() end)
        end)
    end
end

local ShowNotice = CreateNotifySystem()

-- ================== 工具函式 ==================
local function formatTime(seconds)
    local h = math.floor(seconds / 3600)
    local m = math.floor((seconds % 3600) / 60)
    local s = math.floor(seconds % 60)
    return string.format("%02dh %02dm %02ds", h, m, s)
end

-- ================== 核心邏輯處理（完全不動） ==================
local function SafeTriggerBuy(prompt)
    if not LogicState.AutoBuy then return end
    
    local delayTime = math.random(Settings.BuyMinDelay * 1000, Settings.BuyMaxDelay * 1000) / 1000
    task.wait(delayTime)
    
    if prompt and prompt.Parent and LogicState.AutoBuy then
        pcall(function()
            fireproximityprompt(prompt)
        end)
    end
end

ProximityPromptService.PromptShown:Connect(function(prompt)
    if LogicState.AutoBuy then
        task.spawn(SafeTriggerBuy, prompt)
    end
end)

