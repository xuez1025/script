--- 邏輯實作 ---

local selectedTarget = nil
local shipTpToggle = false

-- 獲取目前駕駛的船隻根部件 (通常是船的主體或 VehicleSeat)
local function getMyShip()
    local myChar = LocalPlayer.Character
    if myChar and myChar:FindFirstChild("Humanoid") and myChar.Humanoid.SeatPart then
        -- 獲取船隻模型 (向上尋找模型)
        local current = myChar.Humanoid.SeatPart
        while current.Parent and not current:IsA("Model") do
            current = current.Parent
        end
        return current, myChar.Humanoid.SeatPart
    end
    return nil, nil
end

-- 獲取除了自己正在坐的那個以外的空位
local function getTargetSeat(ship, mySeat)
    for _, part in pairs(ship:GetDescendants()) do
        if (part:IsA("Seat") or part:IsA("VehicleSeat")) and part ~= mySeat and not part.Occupant then
            return part
        end
    end
    return nil
end

-- 更新清單
local function updateList()
    for _, child in pairs(PlayerList:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
    for _, p in pairs(Player:GetPlayers()) do
        if p ~= LocalPlayer then
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, 0, 0, 30)
            btn.Text = p.DisplayName
            btn.BackgroundColor3 = (selectedTarget == p) and Color3.fromRGB(100, 100, 180) or Color3.fromRGB(50, 50, 55)
            btn.TextColor3 = Color3.new(1,1,1)
            btn.Parent = PlayerList
            btn.MouseButton1Click:Connect(function() selectedTarget = p; updateList() end)
        end
    end
end

updateList()

-- 開關
ShipTpBtn.MouseButton1Click:Connect(function()
    shipTpToggle = not shipTpToggle
    ShipTpBtn.Text = "帶船傳送至目標: " .. (shipTpToggle and "ON" or "OFF")
    ShipTpBtn.BackgroundColor3 = shipTpToggle and Color3.fromRGB(180, 60, 60) or Color3.fromRGB(60, 130, 60)
end)

-- 帶船傳送循環
RunService.Heartbeat:Connect(function()
    if shipTpToggle and selectedTarget and selectedTarget.Character then
        local targetHRP = selectedTarget.Character:FindFirstChild("HumanoidRootPart")
        local myShip, mySeat = getMyShip()
        
        if myShip and targetHRP and mySeat then
            local emptySeat = getTargetSeat(myShip, mySeat)
            
            if emptySeat then

                local relativeOffset = myShip:GetPrimaryPartCFrame():Inverse() * emptySeat.CFrame
                myShip:SetPrimaryPartCFrame(targetHRP.CFrame * relativeOffset:Inverse())
            else
                myShip:SetPrimaryPartCFrame(targetHRP.CFrame * CFrame.new(0, 5, 0))
            end
        end
    end
end)

CloseBtn.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)
